{
  "schemaVersion": "0.1.0",
  "name": "YouTube",
  "behavior": "create",
  "noteContentFormat": "![{{schema:name}}]({{url}})\n\n# {{schema:name ?? title}}\n\n## Summary\n\n{{\"Summarize the key points of this video as concise bullet points. Put any people, tools, books, or technologies in [[wikilink]] format. If the page text is insufficient, write: Needs manual review.\"}}\n\n## Notes\n- ",
  "properties": [
    {
      "name": "title",
      "value": "{{schema:name ?? title}}",
      "type": "text"
    },
    {
      "name": "image",
      "value": "{{schema:thumbnailUrl|slice:0}}",
      "type": "text"
    },
    {
      "name": "author",
      "value": "{{schema:author|wikilink}}",
      "type": "multitext"
    },
    {
      "name": "published",
      "value": "{{schema:uploadDate|date:\"YYYY-MM-DD\"}}",
      "type": "date"
    },
    {
      "name": "source",
      "value": "{{url}}",
      "type": "text"
    },
    {
      "name": "created",
      "value": "{{date|date:\"YYYY-MM-DD\"}}",
      "type": "date"
    },
    {
      "name": "tags",
      "value": "clipping, youtube",
      "type": "multitext"
    }
  ],
  "triggers": ["https://www.youtube.com/watch?v="],
  "noteNameFormat": "{{schema:name ?? title}}",
  "path": "0 - Inbox",
  "context": "{{selectorHtml:ytd-engagement-panel-section-list-renderer[visibility$=\"EXPANDED\"]|markdown}}\n\n{{content}}"
}
